{
  "name": "efordo",
  "version": "1.0.0",
  "private": true,
  "description": "eFordo - Chat-first shared life operating system",
  "scripts": {
    "backend:install": "npm --prefix backend/api install",
    "backend:build": "npm --prefix backend/api run build",
    "backend:dev": "npm --prefix backend/api run start:dev",
    "backend:start": "npm --prefix backend/api run start",
    "backend:start:prod": "npm --prefix backend/api run start:prod",
    "backend:test": "npm --prefix backend/api test",
    "backend:lint": "npm --prefix backend/api run lint",
    "frontend:get": "cd frontend/flutter_app && flutter pub get",
    "frontend:analyze": "cd frontend/flutter_app && flutter analyze",
    "frontend:web": "cd frontend/flutter_app && flutter run -d chrome --web-port 5000",
    "frontend:clean": "cd frontend/flutter_app && flutter clean",
    "frontend:build:web": "cd frontend/flutter_app && flutter build web",
    "install:all": "npm run backend:install && npm run frontend:get",
    "dev": "npm run backend:dev",
    "build": "npm --prefix backend/api install --include=dev && npm --prefix backend/api run build",
    "test": "npm --prefix backend/api test",
    "lint": "npm run backend:lint"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@supabase/supabase-js": "^2.108.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  }
}
