{
  "name": "efordo",
  "version": "1.0.0",
  "private": true,
  "description": "eFordo - Chat-first shared life operating system",
  "scripts": {
    "backend:install": "cd backend/api && npm install",
    "backend:build": "cd backend/api && npm run build",
    "backend:dev": "cd backend/api && npm run start:dev",
    "backend:start": "cd backend/api && npm run start",
    "backend:start:prod": "cd backend/api && npm run start:prod",
    "backend:test": "cd backend/api && npm test",
    "backend:lint": "cd backend/api && npm run lint",
    "frontend:get": "cd frontend/flutter_app && flutter pub get",
    "frontend:analyze": "cd frontend/flutter_app && flutter analyze",
    "frontend:web": "cd frontend/flutter_app && flutter run -d chrome --web-port 5000",
    "frontend:clean": "cd frontend/flutter_app && flutter clean",
    "frontend:build:web": "cd frontend/flutter_app && flutter build web",
    "install:all": "npm run backend:install && npm run frontend:get",
    "dev": "npm run backend:dev",
    "build": "npm run backend:build",
    "test": "npm run backend:test",
    "lint": "npm run backend:lint"
  }
}
